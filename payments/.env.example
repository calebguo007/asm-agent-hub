# ═══════════════════════════════════════════════════════════
# ASM × Circle Nanopayments 环境变量
# ═══════════════════════════════════════════════════════════

# ── Circle Gateway ──────────────────────────────────────
# Circle API Key（从 console.circle.com 获取）
CIRCLE_API_KEY=TEST_API_KEY:xxxxxxxx:xxxxxxxx

# ── 钱包Configuration ────────────────────────────────────────────
# Seller 钱包地址（接收 USDC 的地址）
SELLER_ADDRESS=0xYourSellerWalletAddress

# Buyer 钱包私钥（Agent 付款用，仅 testnet！）
BUYER_PRIVATE_KEY=0xYourBuyerPrivateKey

# ── 网络Configuration ────────────────────────────────────────────
# 目标链：arcTestnet（比赛要求）
CHAIN=arcTestnet
# CAIP-2 Network identifier
NETWORK=eip155:1301

# ── ASM Registry ────────────────────────────────────────
# ASM HTTP API 地址
ASM_REGISTRY_URL=http://localhost:3456

# ── 定价 ────────────────────────────────────────────────
# 每次 /api/score 调用的价格（USDC）
SCORE_PRICE=$0.005
# 每次 /api/query 调用的价格（USDC）
QUERY_PRICE=$0.002

# ── ServicePort ────────────────────────────────────────────
PAYMENT_SERVER_PORT=4402
